@page "/power"
@rendermode InteractiveServer

<PageTitle>Power</PageTitle> 
<h3>Возведение в степень</h3>

<div class="power">
    <input type="number" step="0.1" @bind="baseNum" @bind:after="OnBaseChanged" />
    <span>^</span>
    <input type="number" min="0" step="1" @bind="exponent" @bind:after="OnExponentChanged" />
    <button class="btn btn-primary ms-2" @onclick="Calculate">Вычислить</button>
    <div id="result">@result</div>
</div>

@if (steps.Any())
{
    <ol>
        @{
            foreach (double step in steps)
            {
                <li>@step</li>
            }
        }
    </ol>
}