@page "/students/details"
@using Microsoft.EntityFrameworkCore
@using Academy2.Models
@inject IDbContextFactory<Academy2.Data.Academy2Context> DbFactory
@inject NavigationManager NavigationManager
@using Academy2.Components.Pages.TeacherPages;

<PageTitle>Details</PageTitle>
<h3>Student Details </h3>
@* <h1>@student?.last_name @student?.first_name @student?.middle_name  </h1> *@

<div>
    @* <h2></h2> *@
    @if (student != null)
    {
        <div>
            <a href="@($"/students/edit?stud_id={student.stud_id}")">Edit</a> |
            <a href="@($"/students")">Back to List</a>
        </div>
    }
    <hr />
    @if (student is null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {

        <div class="human-container">
            <div class="col-md-4">
                <dl class="row">
                    <dt class="col-sm-2">last_name</dt>
                    <dd class="col-sm-10">@student.last_name</dd>
                    <dt class="col-sm-2">first_name</dt>
                    <dd class="col-sm-10">@student.first_name</dd>
                    <dt class="col-sm-2">middle_name</dt>
                    <dd class="col-sm-10">@student.middle_name</dd>
                    <dt class="col-sm-2">birth_date</dt>
                    <dd class="col-sm-10">@student.birth_date</dd>
                    <dt class="col-sm-2">email</dt>
                    <dd class="col-sm-10">@student.email</dd>
                    <dt class="col-sm-2">phone</dt>
                    <dd class="col-sm-10">@student.phone</dd>
                    @* <dt class="col-sm-2">photo</dt>
                    <dd class="col-sm-10">@student.photo</dd> *@
                    <dt class="col-sm-2">group</dt>
                    <dd class="col-sm-10">@student.Group.group_name</dd>
                </dl>
            </div>
            <div class="photo-container">
                <Photo Human="student" allow_chenge="false" />
            </div>
        </div>
        
    }
</div>

@code {
    private Student? student;

    [SupplyParameterFromQuery]
    private int stud_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        student = await context.Students.Include(s => s.Group).FirstOrDefaultAsync(m => m.stud_id == stud_id);

        if (student is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }
}
